<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# ── Compression ─────────────────────────────────────────────────────────────
# Brotli (preferred — 20-26% smaller than gzip)
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript application/json
    AddOutputFilterByType BROTLI_COMPRESS font/woff2 font/woff image/svg+xml
    BrotliCompressionQuality 6
</IfModule>

# Gzip fallback
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
    AddOutputFilterByType DEFLATE font/woff2 font/woff image/svg+xml
    # Remove broken encodings
    BrowserMatch ^Mozilla/4 gzip-only-text/html
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
</IfModule>

# ── Cache headers for static assets served directly by Apache ────────────────
<IfModule mod_headers.c>
    # Angular hashed assets — filename ends with -XXXXXXXX (8 uppercase base32 chars)
    # Covers: chunk-QJJGTXCS.js, main-YASK6DDW.js, styles-3M62JTIQ.css,
    #         inter-latin-wght-normal-NRMW37G5.woff2, playfair-...-PPGHEFGC.woff2, etc.
    <FilesMatch "-[A-Z0-9]{8}\.(js|css|woff2|woff|ttf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Uploaded recipe images — long random filenames, safe to cache 30 days
    SetEnvIf Request_URI "^/storage/" is_upload
    <FilesMatch "\.(jpg|jpeg|png|webp|gif)$">
        Header set Cache-Control "public, max-age=2592000" env=is_upload
    </FilesMatch>

    # Source maps — cache but not immutable
    <FilesMatch "\.map$">
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>

    # Vary: Accept-Encoding so CDNs store separate compressed copies
    <FilesMatch "\.(js|css|html|json|svg)$">
        Header append Vary Accept-Encoding
    </FilesMatch>
</IfModule>

# ── Mime types ───────────────────────────────────────────────────────────────
<IfModule mod_mime.c>
    AddType application/javascript        .js
    AddType text/css                      .css
    AddType font/woff2                    .woff2
    AddType font/woff                     .woff
    AddType image/svg+xml                 .svg
    AddType image/webp                    .webp
</IfModule>
